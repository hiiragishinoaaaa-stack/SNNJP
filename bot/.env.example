# Discordボットのトークン (Discord Developer Portal から取得)
DISCORD_TOKEN=ここにトークンを入れる

# BOTオーナーのDiscord ID (設定→開発者モードON→自分のプロフから右クリックでコピー)
ADMIN_USER_ID=ここにDiscordIDを入れる

# smmjp.com の APIキー
SMM_API_KEY=ここにAPIキーを入れる

# 全サーバー共通の購入ログ送信チャンネルID
GLOBAL_LOG_CHANNEL_ID=ここにチャンネルIDを入れる

# BOTのステータス表示 (任意)
BOT_STATUS=BOT製作者:@あなたの名前

# パネル下部のフッター表示 (任意)
BOT_FOOTER=BOT製作者:@あなたの名前
